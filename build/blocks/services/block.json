            "UI/UX Design",
            "Brand Identity",
            "Packaging Design",
            "Figma Prototypes"
          ],
          "price": "Starting from $60/hr",
          "linkText": "Book on Upwork",
          "linkUrl": "https://www.upwork.com/freelancers/~01fd2163ff2438e0a6",
          "external": true
        },
        {
          "icon": "code",
          "title": "Development",
          "items": [
            "WordPress / Shopify",
            "Custom Web Apps",
            "React + Django",
            "Speed Optimization"
          ],
          "price": "Starting from $60/hr",
          "linkText": "Book on Upwork",
          "linkUrl": "https://www.upwork.com/freelancers/~01fd2163ff2438e0a6",
          "external": true
        },
        {
          "icon": "rocket",
          "title": "Strategy",
          "items": [
            "SaaS Products",
            "Chrome Extensions",
            "App Development",
            "Launch Planning"
          ],
          "price": "Let's talk",
          "linkText": "Contact me",
          "linkUrl": "#contact",
