{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "as-theme/services",
  "version": "1.0.0",
  "title": "Portfolio Services",
  "category": "as-theme-sections",
  "icon": "screenoptions",
  "description": "Services section with three cards — Design, Development, Strategy.",
