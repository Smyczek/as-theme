    "tag": {
      "type": "string",
      "default": "Services"
    },
    "heading": {
      "type": "string",
      "default": "What I Can Do For You"
    },
    "cards": {
      "type": "array",
      "default": [
        {
          "icon": "palette",
          "title": "Design",
