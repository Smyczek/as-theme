{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "as-theme/murmlo",
  "version": "1.0.0",
  "title": "Portfolio Featured Project",
  "category": "as-theme-sections",
  "icon": "share-alt",
  "description": "Featured project card with details, tags, image, and CTA button. Supports dark/light theme, reversed layout, custom colors, and image positioning.",
  "textdomain": "as-theme",
  "attributes": {
    "tag": {
      "type": "string",
      "default": "Featured Project"
    },
    "title": {
      "type": "string",
      "default": "Project Name"
    },
    "quote": {
      "type": "string",
      "default": "“Comments for the entire internet”"
    },
    "description": {
      "type": "string",
      "default": "The independent discussion layer for any webpage — no site owner permission required."
    },
    "tags": {
      "type": "array",
      "default": [
        "iOS",
        "Android",
        "Chrome",
        "Real-time",
        "AI Moderation"
      ]
    },
    "buttonText": {
      "type": "string",
      "default": "View Project"
    },
    "buttonUrl": {
      "type": "string",
      "default": "https://example.com"
    },
    "availability": {
      "type": "string",
      "default": "Available on iOS · Android · Chrome Extension"
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageFocalPoint": {
      "type": "object",
      "default": {
        "x": 0.5,
        "y": 0.5
      }
    },
    "theme": {
      "type": "string",
      "default": "dark"
    },
    "reversed": {
      "type": "boolean",
      "default": false
    },
    "bgColor": {
      "type": "string",
      "default": ""
    },
    "accentColor": {
      "type": "string",
      "default": ""
    },
    "hoverColor": {
      "type": "string",
      "default": ""
    },
    "textColor": {
      "type": "string",
      "default": ""
    },
    "buttonTextColor": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "className": true
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}