{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "as-theme/footer",
  "version": "1.0.0",
  "title": "Portfolio Footer",
  "category": "as-theme-sections",
  "icon": "minus",
  "description": "Footer section with copyright, tagline, and social links.",
  "textdomain": "as-theme",
  "attributes": {
    "copyright": {
      "type": "string",
      "default": "Your Name"
    },
    "tagline": {
      "type": "string",
      "default": "Designed & built with passion"
    },
    "links": {
      "type": "array",
      "default": [
        {
          "label": "Portfolio",
          "url": "https://example.com"
        },
        {
          "label": "Social",
          "url": "https://example.com"
        },
        {
          "label": "Dribbble",
          "url": "https://example.com"
        },
        {
          "label": "LinkedIn",
          "url": "https://example.com"
        },
        {
          "label": "Website",
          "url": "https://example.com"
        }
      ]
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "className": true
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}