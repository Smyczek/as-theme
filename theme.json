{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "base", "color": "#ffffff", "name": "Base" },
				{ "slug": "base-light", "color": "#f7f8fa", "name": "Base Light" },
				{ "slug": "contrast", "color": "#1a1d27", "name": "Contrast" },
				{ "slug": "text-secondary", "color": "#5a5d6e", "name": "Text Secondary" },
				{ "slug": "text-light", "color": "#8b8e9c", "name": "Text Light" },
				{ "slug": "accent", "color": "#f16232", "name": "Accent" },
				{ "slug": "accent-hover", "color": "#e04f1f", "name": "Accent Hover" },
				{ "slug": "accent-light", "color": "#fef0eb", "name": "Accent Light" },
				{ "slug": "border", "color": "#e8eaed", "name": "Border" },
				{ "slug": "border-light", "color": "#f0f1f3", "name": "Border Light" },
				{ "slug": "dark-bg", "color": "#12141c", "name": "Dark Background" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"name": "Inter",
					"slug": "inter",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "300 800",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Inter-Variable.woff2" ]
						}
					]
				},
				{
					"fontFamily": "'DM Mono', monospace",
					"name": "DM Mono",
					"slug": "dm-mono",
					"fontFace": [
						{
							"fontFamily": "DM Mono",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/DMMono-Regular.woff2" ]
						},
						{
							"fontFamily": "DM Mono",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/DMMono-Medium.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.82rem", "name": "Small" },
				{ "slug": "medium", "size": "1rem", "name": "Medium" },
				{ "slug": "large", "size": "1.2rem", "name": "Large" },
				{
					"slug": "x-large",
					"size": "clamp(2rem, 3.5vw, 2.8rem)",
					"name": "X-Large",
					"fluid": { "min": "2rem", "max": "2.8rem" }
				},
				{
					"slug": "xx-large",
					"size": "clamp(2.2rem, 5vw, 4.2rem)",
					"name": "XX-Large",
					"fluid": { "min": "2.2rem", "max": "4.2rem" }
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "slug": "10", "size": "0.25rem", "name": "Tiny" },
				{ "slug": "20", "size": "0.5rem", "name": "X-Small" },
				{ "slug": "30", "size": "1rem", "name": "Small" },
				{ "slug": "40", "size": "1.5rem", "name": "Medium" },
				{ "slug": "50", "size": "2rem", "name": "Large" },
				{ "slug": "60", "size": "3rem", "name": "X-Large" },
				{ "slug": "70", "size": "4rem", "name": "XX-Large" },
				{ "slug": "80", "size": "6rem", "name": "Section" }
			]
		},
		"layout": {
			"contentSize": "1180px",
			"wideSize": "1400px"
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": true
				}
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--inter)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontWeight": "400",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "1.2rem",
			"padding": {
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontWeight": "800",
					"lineHeight": "1.15"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"link": {
				"color": {
					"text": "inherit"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontSize": "0.9rem",
					"fontWeight": "600"
				},
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "8px"
				},
				"spacing": {
					"padding": {
						"top": "0.85rem",
						"bottom": "0.85rem",
						"left": "1.8rem",
						"right": "1.8rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent-hover)"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "0.85rem",
					"fontWeight": "500"
				},
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}
